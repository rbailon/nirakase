#!/bin/bash
# ==============================================================================
# Nirakase: nirakase-launch-or-focus-tui
# Description: Launches a TUI application inside a terminal or focuses it if already active.
# License: MIT License | Copyright (c) 2026-present rbailon
# ==============================================================================

export PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd):$PATH"

APP_ID="org.nirakase.$(basename "$1")"
LAUNCH_COMMAND="nirakase-launch-tui $@"

exec nirakase-launch-or-focus "$APP_ID" "$LAUNCH_COMMAND"
