#!/usr/bin/env bash
# ==============================================================================
# Nirakase: nirakase-logo
# Description: Displays the official Nirakase ASCII logo with ANSI colors.
# License: MIT License | Copyright (c) 2026-present rbailon
# ==============================================================================

set -uo pipefail

clear
echo -e "\033[32m"
if [ -n "${NIRAKASE_LOGO:-}" ]; then
    # Show the logo loaded from the UWSM environment variable
    echo "$NIRAKASE_LOGO"
elif [ -f "${HOME}/.local/share/nirakase/logo.txt" ]; then
    # Fallback to the physical file if the variable is not set
    cat "${HOME}/.local/share/nirakase/logo.txt"
else
    # Static fallback in case everything else fails
    echo "   _  _ _  _  _ ___  ____  __  _  _  _  ____ ____  ____   "
    echo "   |\\ | |  |\\ | |__\\ |__| /__  |  |\\ |  |___ [__   |__    "
    echo "   | \\| |  | \\| |  \\ |  | \\__  |  | \\|  |___ ___]  |___   "
fi
echo -e "\033[0m"
echo
