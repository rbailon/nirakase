#!/bin/bash
# ==============================================================================
# Nirakase: nirakase-battery-capacity
# Description: Retrieves the current battery charge capacity level.
# License: MIT License | Copyright (c) 2026-present rbailon
# ==============================================================================

battery_info=$(upower -i $(upower -e | grep BAT))

echo "$battery_info" | awk '/energy-full:/ {
    printf "%d", $2
    exit
}'
