#!/usr/bin/env bash

# Nirakase: Power & Profile TUI Manager
# Aesthetic FZF terminal interface to select system power profiles and run system actions.

set -uo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m' # No color

# Check if fzf is installed
if ! command -v fzf >/dev/null 2>&1; then
    echo -e "${RED}[Error] fzf is not installed.${NC}"
    exit 1
fi

# Get current power profile if powerprofilesctl is available
current_profile="Unknown"
if command -v powerprofilesctl >/dev/null 2>&1; then
    current_profile=$(powerprofilesctl get 2>/dev/null || echo "Unknown")
fi

# Helper function to invoke fzf
run_fzf_menu() {
    local prompt="$1"
    local options="$2"
    local header="$3"
    local border_label="$4"
    echo -e "$options" | fzf \
        --prompt="$prompt" \
        --height=12 \
        --border \
        --reverse \
        --header="$header" \
        --border-label="$border_label" \
        --border-label-pos=bottom \
        --info=hidden
}

# Format options with active indicator
perf_indicator=""
bal_indicator=""
saver_indicator=""

case "$current_profile" in
    performance) perf_indicator="  󰄬 (Active)" ;;
    balanced) bal_indicator="  󰄬 (Active)" ;;
    power-saver) saver_indicator="  󰄬 (Active)" ;;
esac

options="󰓅  Performance${perf_indicator}\n󰾆  Balanced${bal_indicator}\n󰌪  Power Saver${saver_indicator}\n---\n  Lock Screen\n  Suspend\n  Reboot\n  Power Off"

choice=$(run_fzf_menu "Power > " "$options" "Power Management (Current: ${current_profile})" " [ ESC: Exit | ENTER: Select | ↑/↓: Move ] ")

if [ -z "$choice" ]; then
    exit 0
fi

case "${choice,,}" in
    *performance*)
        if command -v powerprofilesctl >/dev/null 2>&1; then
            powerprofilesctl set performance
            notify-send -u low "Power Profile" "Switched to Performance Mode 󰓅" -i battery-full
        fi
        ;;
    *balanced*)
        if command -v powerprofilesctl >/dev/null 2>&1; then
            powerprofilesctl set balanced
            notify-send -u low "Power Profile" "Switched to Balanced Mode 󰾆" -i battery-good
        fi
        ;;
    *power*saver*)
        if command -v powerprofilesctl >/dev/null 2>&1; then
            powerprofilesctl set power-saver
            notify-send -u low "Power Profile" "Switched to Power Saver Mode 󰌪" -i battery-caution
        fi
        ;;
    *lock*screen*)
        if command -v swaylock >/dev/null 2>&1; then
            swaylock
        fi
        ;;
    *suspend*)
        systemctl suspend
        ;;
    *reboot*)
        systemctl reboot
        ;;
    *power*off*)
        systemctl poweroff
        ;;
esac
