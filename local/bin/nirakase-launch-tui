#!/bin/bash
# ==============================================================================
# Nirakase: nirakase-launch-tui
# Description: Launches a TUI application inside the default terminal emulator.
# License: MIT License | Copyright (c) 2026-present rbailon
# ==============================================================================

export PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd):$PATH"

exec setsid uwsm-app -- xdg-terminal-exec --app-id=org.nirakase.$(basename $1) -e "$1" "${@:2}"
